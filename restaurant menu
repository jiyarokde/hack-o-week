<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        margin: 0;

        /* Background Image */
        background-image: url("https://images.pexels.com/photos/260922/pexels-photo-260922.jpeg?cs=srgb&dl=pexels-pixabay-260922.jpg&fm=jpg");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    .menu {
        max-width: 1200px;  /* smaller width so grid wraps naturally */
        margin: 20px auto;
        background: rgba(255, 255, 255, 0.92);
        padding: 20px;
        border-radius: 12px;
    }

    h1 {
        text-align: center;
        font-size: 36px;
        margin-bottom: 8px;
    }

    .tagline {
        text-align: center;
        font-size: 16px;
        color: #666;
        margin-bottom: 30px;
    }

    h2 {
        font-size: 28px;
        margin: 30px 0 15px;
        border-bottom: 2px solid #333;
        padding-bottom: 6px;
    }

    /* GRID FOR MENU ITEMS */
    .menu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); /* wraps automatically */
        gap: 15px;
        justify-items: center; /* centers items in grid cell */
    }

    .menu-item {
        background: #fff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: transform 0.2s;
        width: 100%;
        max-width: 180px; /* ensures items don’t stretch */
    }

    .menu-item:hover {
        transform: scale(1.03);
    }

    /* IMAGE */
    .menu-item .img-container {
        width: 100%;
        height: 120px; /* smaller height to fit more items */
        overflow: hidden;
    }

    .menu-item .img-container img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* maintains aspect ratio, focuses on center */
        object-position: center;
    }

    .content {
        padding: 8px;
        text-align: center;
    }

    .item-name {
        font-size: 16px;
        font-weight: bold;
    }

    .description {
        font-size: 12px;
        color: #555;
        margin: 4px 0;
    }

    .price {
        font-size: 14px;
        font-weight: bold;
        color: #222;
    }
</style>
</head>


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Photography Gallery</title>

<style>

body{
    margin:0;
    font-family: Arial, Helvetica, sans-serif;
    background:#808080;
    color:#333;
}

h1{
    text-align:center;
    padding:30px;
    font-size:60px; /* Bigger title */
    color:white;
}

/* Gallery */

.gallery{
    display:grid;
    grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
    padding:40px;
    max-width:1300px;
    margin:auto;
}

.gallery img{
    width:100%;
    height:220px;
    object-fit:cover;
    border-radius:8px;
    cursor:pointer;
    transition: transform .3s, box-shadow .3s;
}

.gallery img:hover{
    transform:scale(1.05);
    box-shadow:0 8px 20px rgba(0,0,0,0.25);
}

/* Lightbox */

.lightbox{
    display:none;
    position:fixed;
    z-index:1000;
    left:0;
    top:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.9);
    justify-content:center;
    align-items:center;
}

.lightbox img{
    max-width:85%;
    max-height:85%;
    border-radius:10px;
}

.close{
    position:absolute;
    top:20px;
    right:40px;
    font-size:45px;
    color:white;
    cursor:pointer;
}

.prev, .next{
    position:absolute;
    top:50%;
    transform:translateY(-50%);
    font-size:50px;
    color:white;
    cursor:pointer;
    padding:20px;
}

.prev{ left:20px; }
.next{ right:20px; }

.prev:hover, .next:hover, .close:hover{
    color:yellow;
}

</style>
</head>

<body>

<h1>📸 Photographer Image Gallery</h1>

<div class="gallery">

<img src="https://wallpaperaccess.com/full/1688623.jpg" onclick="openLightbox(0)">
<img src="https://picsum.photos/id/1016/600/400" onclick="openLightbox(1)">
<img src="https://picsum.photos/id/1018/600/400" onclick="openLightbox(2)">
<img src="https://wallpaperaccess.com/full/4182746.jpg">
<img src="https://picsum.photos/id/1024/600/400" onclick="openLightbox(4)">
<img src="https://picsum.photos/id/1025/600/400" onclick="openLightbox(5)">
<img src="https://tse1.mm.bing.net/th/id/OIP.g8GvZl4kA1u3xtPUBvXGmAHaEK?rs=1&pid=ImgDetMain&o=7&rm=3">
<img src="https://wallpaperaccess.com/full/536252.jpg">
<img src="https://picsum.photos/id/1035/600/400" onclick="openLightbox(8)">
<img src="https://picsum.photos/id/1037/600/400" onclick="openLightbox(9)">
<img src="https://picsum.photos/id/1040/600/400" onclick="openLightbox(10)">
<img src="https://picsum.photos/id/1041/600/400" onclick="openLightbox(11)">
<img src="https://picsum.photos/id/1043/600/400" onclick="openLightbox(12)">
<img src="https://picsum.photos/id/1050/600/400" onclick="openLightbox(13)">
<img src="https://picsum.photos/id/1052/600/400" onclick="openLightbox(14)">
<img src="https://picsum.photos/id/1060/600/400" onclick="openLightbox(15)">
<img src="https://picsum.photos/id/1065/600/400" onclick="openLightbox(16)">
<img src="https://picsum.photos/id/1070/600/400" onclick="openLightbox(17)">
<img src="https://picsum.photos/id/1074/600/400" onclick="openLightbox(18)">
<img src="https://picsum.photos/id/1080/600/400" onclick="openLightbox(19)">
<img src="https://picsum.photos/id/1082/600/400" onclick="openLightbox(20)">
<img src="https://picsum.photos/id/1084/600/400" onclick="openLightbox(21)">
<img src="https://images.freecreatives.com/wp-content/uploads/2016/02/Cute-Purple-Flower-Background.jpg">
<img src="https://cdn.wallpapersafari.com/99/76/VgTNKG.jpg">

</div>

<div class="lightbox" id="lightbox">

<span class="close" onclick="closeLightbox()">&times;</span>
<span class="prev" onclick="changeImage(-1)">&#10094;</span>

<img id="lightbox-img">

<span class="next" onclick="changeImage(1)">&#10095;</span>

</div>

<script>

let images = [
"https://picsum.photos/id/1015/1200/800",
"https://picsum.photos/id/1016/1200/800",
"https://picsum.photos/id/1018/1200/800",
"https://wallpaperaccess.com/full/4182746.jpg",
"https://picsum.photos/id/1024/1200/800",
"https://picsum.photos/id/1025/1200/800",
"https://wallpaperaccess.com/full/4182746.jpg",
"https://wallpaperaccess.com/full/536252.jpg",
"https://picsum.photos/id/1035/1200/800",
"https://picsum.photos/id/1037/1200/800",
"https://picsum.photos/id/1040/1200/800",
"https://picsum.photos/id/1041/1200/800",
"https://picsum.photos/id/1043/1200/800",
"https://picsum.photos/id/1050/1200/800",
"https://picsum.photos/id/1052/1200/800",
"https://picsum.photos/id/1060/1200/800",
"https://picsum.photos/id/1065/1200/800",
"https://picsum.photos/id/1070/1200/800",
"https://picsum.photos/id/1074/1200/800",
"https://picsum.photos/id/1080/1200/800",
"https://picsum.photos/id/1082/1200/800",
"https://picsum.photos/id/1084/1200/800",
"https://images.freecreatives.com/wp-content/uploads/2016/02/Cute-Purple-Flower-Background.jpg",
"https://cdn.wallpapersafari.com/99/76/VgTNKG.jpg"
];

let currentIndex = 0;

function openLightbox(index){
currentIndex=index;
document.getElementById("lightbox").style.display="flex";
document.getElementById("lightbox-img").src=images[currentIndex];
}

function closeLightbox(){
document.getElementById("lightbox").style.display="none";
}

function changeImage(step){
currentIndex += step;

if(currentIndex < 0)
currentIndex = images.length - 1;

if(currentIndex >= images.length)
currentIndex = 0;

document.getElementById("lightbox-img").src = images[currentIndex];
}

</script>

</body>
</html>
